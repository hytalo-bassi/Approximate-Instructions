FROM lscad/base-riscv-gem5-base:latest

ARG SCONS_BUILD_ARG
ARG BUILD_JOBS
ARG GEM5_VARIANT="gem5.fast"

COPY patches/gem5/decoder.isa gem5/src/arch/riscv/isa/decoder.isa
COPY Approx_Instructions/f32_addx.c gem/ext/softfloat/f32_addx.c
COPY Approx_Instructions/f32_subx.c gem/ext/softfloat/f32_subx.c
COPY Approx_Instructions/s_addMagsF32x.c gem/ext/softfloat/s_addMagsF32x.c
COPY Approx_Instructions/s_subMagsF32x.c gem/ext/softfloat/s_subMagsF32x.c

RUN cd gem5 && \
    if [ -n "${SCONS_BUILD_ARG}" ]; then \
        scons build/RISCV/${GEM5_VARIANT} ${SCONS_BUILD_ARG}; \
    else \
        scons build/RISCV/${GEM5_VARIANT} --linker=gold -j ${BUILD_JOBS:-$(( ( $(nproc) + 1 ) / 2 ))}; \
    fi

WORKDIR /workspace
